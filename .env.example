# Leave empty in development to use relative /api requests through Vite proxy.
VITE_API_BASE_URL=

# Backend origin for Vite dev proxy (local or ngrok).
# Example local: http://localhost:8080
# Example ngrok: https://your-tunnel.ngrok-free.app
VITE_DEV_API_PROXY_TARGET=http://localhost:8080
